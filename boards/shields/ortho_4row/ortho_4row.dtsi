#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/mouse.h>
#include <physical_layouts.dtsi>

/ {
    // kscan 定義 (左右共通の配線を想定。実際のピンはあなたの回路図に合わせて修正)
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
        // ↓ 以下の行は元の ortho_4row_right.overlay の内容をコピー
        row-gpios = <&akdk_d 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
        col-gpios = <&akdk_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                  , <&akdk_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
    };

    // マトリックスの変換 (14列 x 5行)
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <5>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
            RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8)
        >;
        // 左右分割のオフセットは以下の行で設定。右側は col-offset = <7>;
        // ここでは左側用に <0> を指定。右側は別の .dtsi で上書きする
        col-offset = <0>;
    };

    // 物理レイアウト (layouts.dtsi の内容をこちらに統合しても良い)
    ortho_4row_physical_layout: ortho_4row_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Ortho 4row Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys = 
            <&key_physical_attrs 100 100    0   12       0     0    12>
            , <&key_physical_attrs 100 100  100   12       0   100    12>
            /* ... 以下、あなたが keymap.keymap に書いた全てのキー定義 ... */
            ;
    };

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &ortho_4row_physical_layout;
    };
};
